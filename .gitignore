$gitignore = @"
# Ambiente
backend/.env
frontend/.env

# Banco de dados
backend/database.sqlite
backend/database.sqlite-shm
backend/database.sqlite-wal

# Uploads
backend/uploads/

# Dependências
node_modules/
backend/node_modules/
frontend/node_modules/

# Build
frontend/dist/

# Logs
*.log
"@

[System.IO.File]::WriteAllText("C:\Users\migue\TalentMind\.gitignore", $gitignore, [System.Text.Encoding]::UTF8)